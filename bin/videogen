#!/usr/bin/env bash
# Stable entrypoint for the `videogen` CLI regardless of whether
# the venv is activated. Claude Code / Qwen Code shell out without
# inheriting an activated venv, so they invoke this shim.
set -euo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$HERE/.." && pwd)"
PY="$ROOT/.venv/bin/python"
if [[ ! -x "$PY" ]]; then
  echo "videogen shim: $PY missing. Run: cd $ROOT && python3 -m venv .venv && .venv/bin/pip install -e ." >&2
  exit 127
fi
exec "$PY" -m videogen.cli "$@"

# Copy to .env and fill in. Loaded automatically by videogen CLI.

# DashScope (阿里云百炼) API Key — REQUIRED
# 获取: https://help.aliyun.com/zh/model-studio/get-api-key
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 地域: beijing | singapore (默认 beijing)
VIDEOGEN_REGION=beijing

# 视频模型阵营: happyhorse | wan (默认 happyhorse)
# 决定 t2v / i2v / r2v 落到哪个 DashScope 模型家族:
#   happyhorse → happyhorse-1.0-{t2v,i2v,r2v}
#   wan        → wan2.7-{t2v-2026-04-25,i2v-2026-04-25,r2v}
# 可被 storyboard.provider (per-episode, 由 `scene compile --provider`
# 写入) 与 `videogen render --provider` 覆盖。功能差异:
#   - HappyHorse r2v 不支持 reference_voice 与 first_frame 续帧
#     (chain 续帧时渲染层会自动降级为 i2v)
#   - HappyHorse 不支持 negative_prompt / prompt_extend
#   - HappyHorse duration 下限为 3s (Wan 为 2s)
VIDEOGEN_VIDEO_PROVIDER=happyhorse

# 默认模型档位
VIDEOGEN_DEFAULT_RESOLUTION=720P
VIDEOGEN_DEFAULT_RATIO=16:9

# 单段视频默认时长 (秒)。默认 15 = t2v/i2v/r2v 的最大值。
# 段数越少剪切越少、人物一致性越强、API 成本越低。
# 各 provider 的下限不同 (Wan 2s, HappyHorse 3s)，由 provider 在渲染前自动钳。
VIDEOGEN_DEFAULT_CLIP_DURATION=15

# 总时长“预算关卡”阈值 (秒)。导演 Skill 看到 storyboard 总时长超过此值时，
# 必须先打印预估并向用户确认，避免一次烧掉一大笔 API 费用。
VIDEOGEN_LONG_CONFIRM_S=180

# 并发提交的最大任务数
VIDEOGEN_MAX_CONCURRENCY=4

# 轮询间隔 (秒)
VIDEOGEN_POLL_INTERVAL=15

# 项目根目录（生成视频与状态落盘）
VIDEOGEN_PROJECTS_DIR=./projects

# === Per-clip review + auto-rewrite (Zone 3) ==================================
# 每个 clip 渲染完后调用 qwen3-vl-plus 打分; score < 阈值 → 自动改 prompt + 重渲。
# 评分 = 六轴均分: logic / proportion / physics / style / cast_match / dialog_attribution。
# 其中 cast_match 用 cast.json 里的角色参考图与视频里同名角色比对身份;
# dialog_attribution 检查台词归属是否被换错(A 的台词被 B 念)。
# 阈值范围 0..10, 推荐 7.0。降低=更快通过, 提高=质量更严。
VIDEOGEN_REVIEW_THRESHOLD=7.0

# 视频审片模型 (DashScope multimodal). 设为空字符串 "" 则关闭审片。
VIDEOGEN_REVIEW_MODEL=qwen3-vl-plus

# 自动 prompt 改写模型 (DashScope text). 设为空字符串 "" 则关闭自动改写,
# 重试时仅原 prompt 重渲(只对偶发模型抖动有效)。
VIDEOGEN_REWRITE_MODEL=qwen-plus

# 单个 shot 最多渲染次数(含首次)。前 N-1 轮 CLI 自动改 prompt; 第 N 轮失败
# 写 needs_director_rewrite.json 并 exit 3, 由导演 Skill 介入。
VIDEOGEN_MAX_RETRY=3
